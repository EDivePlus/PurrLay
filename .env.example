# Copy to `.env` and fill in. `.env` is gitignored.

# Shared secret between balancer and relay. Generate with: openssl rand -hex 32
PURR_SECRET=change-me-to-a-long-random-string

# Single public hostname used for both the balancer HTTP API (at :443)
# and the relay WebSocket (at :6942). DNS must already point here.
PURR_DOMAIN=relay.ediveplus.phil.muni.cz

# Region identifier reported by this relay to the balancer. Clients pick a relay by region.
RELAY_REGION=Czechia

# Name of the Traefik certresolver defined in your Traefik static config
# (e.g. `letsencrypt`, `cloudflare`).
TRAEFIK_CERT_RESOLVER=letsencrypt
